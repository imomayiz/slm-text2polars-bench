    "id": "s001",
    "question": "How many employees are in the Eng department?",
    "category": "filter",
    "difficulty": "easy",
    "schema": {
      "df": {
        "name": "String",
        "department": "String",
        "salary": "Float64"
      }
    },
    "data": {
      "df": [
        {"name": "Alice", "department": "Eng", "salary": 120000.0},
        {"name": "Bob", "department": "Eng", "salary": 95000.0},
        {"name": "Carol", "department": "Sales", "salary": 85000.0},
        {"name": "Dan", "department": "Sales", "salary": 110000.0}
      ]
    },
    "reference_code": "result = df.filter(pl.col(\"department\") == \"Eng\").height",
    "expected_output": {
      "kind": "scalar",
      "value": 2
    },
    "tolerance": {
      "order_matters": false,
      "float_atol": 1e-06
    }
